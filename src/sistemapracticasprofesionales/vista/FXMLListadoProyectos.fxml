<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemapracticasprofesionales.controlador.FXMLListadoProyectosController">
   <children>
      <Button layoutX="792.0" layoutY="605.0" mnemonicParsing="false" onAction="#clilcRegresar" text="Regresar" />
      <TableView fx:id="tv_proyectos" layoutX="30.0" layoutY="161.0" prefHeight="416.0" prefWidth="840.0">
        <columns>
          <TableColumn fx:id="col_nombre" prefWidth="149.0" text="Nombre" />
            <TableColumn fx:id="col_estudiante" prefWidth="309.0" text="Nombre estudiante" />
            <TableColumn fx:id="col_organizacionVinculada" prefWidth="223.0" text="Organización vinculada" />
            <TableColumn fx:id="col_fechaFinalizacion" prefWidth="158.0" text="Fecha finalización" />
        </columns>
      </TableView>
      <Label layoutX="30.0" layoutY="53.0" text="Listado de proyectos">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <HBox alignment="CENTER" layoutX="30.0" layoutY="96.0" prefHeight="40.0" prefWidth="840.0" spacing="10.0">
         <children>
            <TextField fx:id="txt_nombreBusqueda" promptText="Buscar por nombre" />
            <Button mnemonicParsing="false" onAction="#clicBuscar" text="Buscar" />
            <Button mnemonicParsing="false" onAction="#clicVerTodos" text="Ver todos" />
            <HBox alignment="CENTER_RIGHT" prefHeight="56.0" prefWidth="457.0" spacing="10.0" />
         </children>
      </HBox>
      <MenuBar prefHeight="32.0" prefWidth="900.0">
         <menus>
            <Menu mnemonicParsing="false" text="Analiticas">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clilcGenerarReporteIndicadores" text="Generar reporte de indicadores" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Proyectos">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clilcRegistrarProyecto" text="Registrar" />
                  <MenuItem mnemonicParsing="false" onAction="#clicVerListadoProyecto" text="Ver listado" />
                  <MenuItem mnemonicParsing="false" onAction="#clilcAsignarProyecto" text="Asignar proyecto" />
                  <MenuItem mnemonicParsing="false" onAction="#clilcGenerarOficioDeAsignacion" text="Generar oficio de asignación" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Organizaciones vinculadas">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clilcRegistrarOrganizacionVinculada" text="Registrar organizacion vinculada" />
                  <MenuItem mnemonicParsing="false" onAction="#clilcVerListadoOrganizacionesVinculadas" text="Ver listado" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Estudiantes">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clilcVerListadoEstudiantes" text="Ver listado" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Mas">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clicCerrarSesion" text="Cerrar sesión" />
               </items>
            </Menu>
         </menus>
      </MenuBar>
      <Button layoutX="681.0" layoutY="605.0" mnemonicParsing="false" onAction="#clicVerDetalles" text="Ver detalles" />
   </children>
</AnchorPane>
