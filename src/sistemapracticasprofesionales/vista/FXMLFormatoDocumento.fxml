<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.effect.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemapracticasprofesionales.controlador.FXMLFormatoDocumentoController">
   <children>
      <VBox layoutX="450.0" layoutY="272.0" prefHeight="180.0" prefWidth="423.0" spacing="10.0">
         <children>

            <GridPane hgap="15.0" prefHeight="50.0" prefWidth="820.0" vgap="25.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="240.0" minWidth="10.0" prefWidth="67.0" />
                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="650.0" minWidth="10.0" prefWidth="295.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="25.0" prefHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="25.0" prefHeight="35.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <Label text="Documento:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <ComboBox fx:id="cb_documentos" prefHeight="25.0" prefWidth="231.0" promptText="Seleccione un documento" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label text="Archivo" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <HBox prefHeight="31.0" prefWidth="600.0" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <children>
                        <TextField fx:id="txt_archivo" editable="false" prefHeight="25.0" prefWidth="209.0" promptText="Ningún archivo seleccionado" />
                        <Button mnemonicParsing="false" onAction="#clicSeleccionarArchivo" prefHeight="25.0" prefWidth="87.0" text="Seleccionar" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </GridPane>

            <Label fx:id="lbl_error" textFill="RED" />

            <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="840.0" spacing="25.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#clicSubirFormato" prefHeight="31.0" prefWidth="140.0" text="Subir formato" />
                  <Button mnemonicParsing="false" onAction="#clicRegresar" prefHeight="31.0" prefWidth="110.0" text="Regresar" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
      <VBox layoutX="24.0" layoutY="105.0" prefHeight="525.0" prefWidth="397.0" spacing="25.0">
         <children>

            <Label text="Formatos registrados">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>

            <TableView fx:id="tv_formatos" prefHeight="468.0" prefWidth="397.0">
               <columns>
                  <TableColumn fx:id="col_tipoDocumento" prefWidth="253.0" text="Documento" />
                  <TableColumn fx:id="col_estadoFormato" prefWidth="143.0" text="Estado" />
               </columns>
            </TableView>
         </children>
      </VBox>
      <VBox layoutX="24.0" layoutY="32.0" prefHeight="73.0" prefWidth="416.0">
         <children>
            <Label text="Formatos de documentos">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

                  <Label text="Seleccione el tipo de documento y el archivo que desea subir como formato." />
         </children>
      </VBox>
      <MenuBar layoutY="1.0" prefHeight="27.0" prefWidth="902.0">
         <menus>
            <Menu mnemonicParsing="false" text="Expedientes">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clicConsultarExpedientes" text="Consultar expedientes" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Formatos">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clicSubirFormatos" text="Subir formatos" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Fechas de Entrega">
               <items>
                  <MenuItem mnemonicParsing="false" onAction="#clicFechasEntrega" text="Fechas de entrega" />
               </items>
            </Menu>
         </menus>
      </MenuBar>
   </children>
</AnchorPane>
