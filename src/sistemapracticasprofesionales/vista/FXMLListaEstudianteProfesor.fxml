<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="680.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/8.0.202"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sistemapracticasprofesionales.controlador.FXMLListaEstudianteProfesorController">

    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="Expedientes">
                    <items>
                        <MenuItem mnemonicParsing="false"
                                  onAction="#clicConsultarExpedientes"
                                  text="Consultar expedientes" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Formatos">
                    <items>
                        <MenuItem mnemonicParsing="false"
                                  onAction="#clicSubirFormatos"
                                  text="Subir formatos" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Fechas de Entrega">
                    <items>
                        <MenuItem mnemonicParsing="false"
                                  onAction="#clicFechasEntrega"
                                  text="Asignar fechas" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="25.0">
            <padding>
                <Insets bottom="25.0" left="70.0" right="70.0" top="25.0" />
            </padding>

            <Text text="ESTUDIANTES">
                <font>
                    <Font name="System Bold" size="22.0" />
                </font>
            </Text>

            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <TextField fx:id="txt_busqueda" prefWidth="230.0"
                           promptText="nombre / matrícula" />

                <ComboBox fx:id="cb_filtro" prefWidth="170.0"
                          promptText="Filtro" />

                <Button mnemonicParsing="false" onAction="#clicBuscar"
                        prefWidth="110.0" text="Buscar" />
            </HBox>

            <TableView fx:id="tv_estudiantes" prefHeight="310.0"
                       prefWidth="760.0">
                <columns>
                    <TableColumn fx:id="col_matricula"
                                 prefWidth="160.0"
                                 text="Matrícula" />
                    <TableColumn fx:id="col_nombreEstudiante"
                                 prefWidth="210.0"
                                 text="Nombre estudiante" />
                    <TableColumn fx:id="col_proyecto"
                                 prefWidth="250.0"
                                 text="Proyecto" />
                    <TableColumn fx:id="col_calificacion"
                                 prefWidth="135.0"
                                 text="Calificación" />
                </columns>
            </TableView>

            <HBox alignment="CENTER" spacing="35.0">
                <Button mnemonicParsing="false"
                        onAction="#clicVerExpediente"
                        prefWidth="150.0"
                        text="Ver expediente" />
                <Button mnemonicParsing="false"
                        onAction="#clicRegresar"
                        prefWidth="150.0"
                        text="Regresar" />
            </HBox>
        </VBox>
    </center>
</BorderPane>