<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="818.0" prefWidth="607.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemapracticasprofesionales.controlador.FXMLFormularioProfesorController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="930.0" prefWidth="607.0" spacing="30.0" style="-fx-background-color: white;" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Formulario de Profesor">
               <font>
                  <Font name="System Bold" size="30.0" />
               </font>
               <padding>
                  <Insets bottom="30.0" top="30.0" />
               </padding>
            </Label>
            <HBox prefHeight="31.0" prefWidth="560.0" spacing="10.0">
               <children>
                  <Label prefHeight="31.0" prefWidth="275.0" text="Número de empleado" />
                  <TextField fx:id="txt_numeroEmpleado" prefHeight="31.0" prefWidth="479.0" promptText="Ingrese el número de empleado" />
               </children>
            </HBox>
            <HBox prefHeight="31.0" prefWidth="560.0" spacing="10.0">
               <children>
                  <Label prefHeight="31.0" prefWidth="275.0" text="Nombre" />
                  <TextField fx:id="txt_nombre" prefHeight="31.0" prefWidth="479.0" promptText="Nombre" />
