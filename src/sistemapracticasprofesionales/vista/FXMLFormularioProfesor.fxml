            </HBox>
            <HBox prefHeight="31.0" prefWidth="560.0" spacing="10.0">
               <children>
                  <Label prefHeight="31.0" prefWidth="275.0" text="Teléfono" />
                  <TextField fx:id="txt_telefono" prefHeight="31.0" prefWidth="479.0" promptText="Telefono (10 digitos)" />
               </children>
            </HBox>
            <HBox prefHeight="31.0" prefWidth="560.0" spacing="10.0">
               <children>
                  <Label prefHeight="31.0" prefWidth="275.0" text="Correo" />
                  <TextField fx:id="txt_correo" prefHeight="31.0" prefWidth="479.0" promptText="Correo electrónico" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="31.0" prefWidth="560.0" spacing="10.0">
