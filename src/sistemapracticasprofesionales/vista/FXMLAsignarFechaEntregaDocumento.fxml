<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane id="AnchorPane" prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemapracticasprofesionales.controlador.FXMLAsignarFechaEntregaDocumentoController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" prefHeight="590.0" prefWidth="840.0" spacing="15.0">
         <children>
            <Label text="Asignar fecha de entrega">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <Label text="Seleccione el documento y establezca la fecha límite de entrega." />

            <GridPane hgap="15.0" prefWidth="840.0" vgap="20.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" prefWidth="190.0" />
                  <ColumnConstraints hgrow="SOMETIMES" prefWidth="650.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints maxHeight="27.0" minHeight="22.0" prefHeight="27.0" />
                  <RowConstraints maxHeight="20.0" minHeight="15.0" prefHeight="15.0" />
               </rowConstraints>
               <children>
                  <Label text="Documento" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <ComboBox fx:id="cb_documentos" prefHeight="31.0" prefWidth="600.0" promptText="Seleccione un documento" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label text="Fecha de entrega" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <DatePicker fx:id="dp_fechaEntrega" editable="false" prefHeight="31.0" prefWidth="250.0" promptText="Seleccione una fecha" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               </children>
            </GridPane>

            <Label fx:id="lbl_error" textFill="RED" />

            <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="840.0" spacing="25.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#clicAsignarFecha" prefHeight="31.0" prefWidth="140.0" text="Asignar fecha" />
                  <Button mnemonicParsing="false" onAction="#clicActualizar" prefHeight="31.0" prefWidth="120.0" text="Actualizar" />
                  <Button mnemonicParsing="false" onAction="#clicRegresar" prefHeight="31.0" prefWidth="110.0" text="Regresar" />
               </children>
            </HBox>

            <Separator prefWidth="840.0" />

            <Label text="Fechas asignadas">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>

            <TableView fx:id="tv_fechasEntrega" prefHeight="330.0" prefWidth="840.0">
               <columns>
                  <TableColumn fx:id="col_tipoDocumento" prefWidth="330.0" text="Documento" />
                  <TableColumn fx:id="col_valor" prefWidth="90.0" text="Valor" />
                  <TableColumn fx:id="col_fechaEntrega" prefWidth="180.0" text="Fecha de entrega" />
                  <TableColumn fx:id="col_estadoFecha" prefWidth="160.0" text="Estado" />
               </columns>
            </TableView>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
